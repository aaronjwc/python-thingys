import string
import secrets

def get_user_input():
    while True:
        try:
            length = int(input("Enter password length: "))
            if length <= 0:
                print("Length must be greater than 0.")
                continue
            break
        except ValueError:
            print("Please enter a valid number.")

    use_upper = input("Include uppercase? (y/n): ").lower() == 'y'
    use_digits = input("Include numbers? (y/n): ").lower() == 'y'
    use_symbols = input("Include symbols? (y/n): ").lower() == 'y'

    if not (use_upper or use_digits or use_symbols):
        print("You must select at least one additional character type.")
        return None

    return length, use_upper, use_digits, use_symbols


def generate_password(length, use_upper, use_digits, use_symbols):
    lowercase = string.ascii_lowercase
    uppercase = string.ascii_uppercase
    digits = string.digits
    symbols = string.punctuation

    pool = lowercase
    password_chars = []

    password_chars.append(secrets.choice(lowercase))

    if use_upper:
        pool += uppercase
        password_chars.append(secrets.choice(uppercase))
    if use_digits:
        pool += digits
        password_chars.append(secrets.choice(digits))
    if use_symbols:
        pool += symbols
        password_chars.append(secrets.choice(symbols))

    if length < len(password_chars):
        raise ValueError("Length too short for selected character types.")

    for _ in range(length - len(password_chars)):
        password_chars.append(secrets.choice(pool))

    secrets.SystemRandom().shuffle(password_chars)

    return ''.join(password_chars)


def main():
    print("=== Password Generator ===")

    while True:
        user_input = get_user_input()
        if user_input is None:
            continue

        length, use_upper, use_digits, use_symbols = user_input

        try:
            password = generate_password(length, use_upper, use_digits, use_symbols)
            print("\nGenerated password:", password)
        except ValueError as e:
            print("Error:", e)
            continue

        again = input("\nGenerate another? (y/n): ").lower()
        if again != 'y':
            print("Exiting...")
            break


if __name__ == "__main__":
    main()
